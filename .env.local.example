# Copy to .env.local and fill in values (use KEY=value — no "const" or quotes around keys)

# Supabase: Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Server-only: Project Settings → API → service_role (never expose to the browser).
# Required for /api/daily-summary to write daily_summaries when RLS blocks the anon key.
SUPABASE_SERVICE_ROLE_KEY=

# Used by quiz-hint, affirmation, and debrief. Debrief also accepts GEMINI_API_KEY if set.
GOOGLE_GEMINI_API_KEY=
# Optional override (default: gemini-1.5-flash). If that model is unavailable, newer ids are tried automatically.
# GEMINI_MODEL=
RESEND_API_KEY=

# Resend — optional verified sender (defaults to onboarding@resend.dev)
# RESEND_FROM_EMAIL=Ad Astra <noreply@yourdomain.com>

# Required for /api/send-code and /api/verify-code (e.g. openssl rand -hex 32)
CODE_SIGNING_SECRET=a_very_long_random_string_here_12345

# --- Program calendar (May 1 cohort; 40 mission days by default) ---
# Before launch date: dashboard/quiz use "legacy" sequencing (completed days + student.current_day).
# Optional: simulate the class mission day while testing: set 1–40
# NEXT_PUBLIC_PROGRAM_TEST_MISSION_DAY=4
#
# Launch (local date): first mission day
NEXT_PUBLIC_PROGRAM_LAUNCH_DATE=2026-05-01
# Total missions (cap 40)
NEXT_PUBLIC_PROGRAM_TOTAL_DAYS=40
# consecutive = each calendar day is the next mission (day 40 ends ~June 9 from May 1)
# weekdays = May 1 is day 1, then weekdays only (~40 weekdays extends past mid-June)
NEXT_PUBLIC_PROGRAM_DAY_STRATEGY=consecutive

# Optional: May 1 "reset" for a new cohort — only rows created at/after this time count toward
# progress (needs created_at on daily_summaries and responses). Example: May 1, 2026 05:00 UTC
# NEXT_PUBLIC_PROGRAM_PROGRESS_CUTOVER=2026-05-01T05:00:00.000Z

# Highest mission day students may open (quiz + review). Uncomment for Day-1-only launch (locks 2–40):
# NEXT_PUBLIC_PROGRAM_MAX_MISSION_DAY=1
# Raise when the cohort advances. Omit to unlock through the calendar only.